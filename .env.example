# Salesforce — connected app
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_API_VERSION=62.0

# Salesforce — auth flow: "username_password" | "jwt" | "auto" (default)
SF_AUTH_FLOW=auto
# "login" for production, "test" for sandboxes
SF_DOMAIN=login

# Username/password flow
SF_USERNAME=integration.user@yourorg.com
SF_PASSWORD=your_password
SF_SECURITY_TOKEN=your_security_token

# Connected app JWT flow (use ONE of these)
SF_JWT_KEY_FILE=./server.key
# SF_JWT_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Entra ID — token validation
ENTRA_TENANT_ID=your_azure_tenant_id
ENTRA_CLIENT_ID=your_api_app_registration_client_id
ENTRA_AUTHORITY=https://login.microsoftonline.com/your_tenant_id

# API settings
API_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://membercenter.scde.sc.gov
